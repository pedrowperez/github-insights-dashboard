# Conexao com o PostgreSQL (Neon, Supabase ou local).
# Exemplo Neon: postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://usuario:senha@host:5432/github_dashboard?sslmode=require

# Segredo usado para assinar os tokens JWT (use uma string longa e aleatoria)
JWT_SECRET=troque-este-segredo-por-uma-string-aleatoria-bem-longa
JWT_EXPIRES_IN=1h

# URL do frontend permitida no CORS
CLIENT_URL=http://localhost:5173

# (Opcional) Token do GitHub para aumentar o limite de requisicoes (5000/h em vez de 60/h)
GITHUB_TOKEN=

# Porta do servidor
PORT=3000
