# Conexao com o PostgreSQL (Neon, Supabase ou local).
#
# --- Supabase LOCAL / dev (conexao direta) ---
# DATABASE_URL=postgresql://postgres:SENHA@db.SEU-PROJETO.supabase.co:5432/postgres
#
# --- Supabase no RENDER (Session Pooler, IPv4) ---
# UI atual: abra o PROJETO > botao "Connect" (topo) > Session pooler > porta 5432 > Copy.
# NAO monte a URL manualmente. NAO use db.*.supabase.co no Render (IPv6).
DATABASE_URL=postgresql://usuario:senha@host:5432/postgres

# SSL na conexao com o banco: 'true' para Neon/Supabase, 'false' para Postgres local/Docker
DB_SSL=true

# Segredo usado para assinar os tokens JWT (use uma string longa e aleatoria)
JWT_SECRET=troque-este-segredo-por-uma-string-aleatoria-bem-longa
# Validade do access token (curta) e do refresh token (em dias)
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_DAYS=7

# URL do frontend permitida no CORS
CLIENT_URL=http://localhost:5173

# (Opcional) Token do GitHub para aumentar o limite de requisicoes (5000/h em vez de 60/h)
GITHUB_TOKEN=

# Porta do servidor
PORT=3000
